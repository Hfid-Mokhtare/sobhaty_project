<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- السمة الأساسية للتطبيق -->
    <style name="Theme.Sobhaty" parent="android:Theme.Material.Light.NoActionBar" />

    <!-- سمة شاشة البداية (Splash Screen) -->
    <style name="Theme.App.Starting" parent="Theme.SplashScreen">
        <!-- خلفية الشاشة بالكامل -->
        <item name="windowSplashScreenBackground">#00441b</item>
        
        <!-- استخدام الطبقة الأمامية فقط (الشعار) لمنع القص -->
        <item name="windowSplashScreenAnimatedIcon">@mipmap/ic_launcher_foreground</item>
        
        <!-- السمة التي سينتقل إليها التطبيق بعد انتهاء الشاشة -->
        <item name="postSplashScreenTheme">@style/Theme.Sobhaty</item>
    </style>
</resources>
